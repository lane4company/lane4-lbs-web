{
  "executionRoleArn": "arn:aws:iam::885105454457:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/lane4-lbs-web",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "portMappings": [
        {
          "hostPort": 8080,
          "protocol": "tcp",
          "containerPort": 8080
        }
      ],
      "cpu": 0,
      "image": "885105454457.dkr.ecr.ap-northeast-2.amazonaws.com/lane4-lbs-web:prod",
      "essential": true,
      "name": "lane4-lbs-web"
    }
  ],
  "memory": "512",
  "family": "lane4-lbs-web",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "networkMode": "awsvpc",
  "cpu": "256"
}
