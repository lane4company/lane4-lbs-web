# ─────────────────────────────────────────────────────────────
# lane4-lbs-web 환경변수 (전체 키 문서화)
# ─────────────────────────────────────────────────────────────

# NextAuth 콜백/쿠키 base URL (배포 시 실제 도메인)
NEXTAUTH_URL=http://localhost:3200

# NextAuth JWT/세션 암호화 시크릿 (openssl rand -base64 32 로 생성)
NEXTAUTH_SECRET=changeme-generate-a-strong-secret

# admin-api lbs/v2/* 백엔드 base URL
NEXT_PUBLIC_API_URL=http://localhost:8080

# 무활동 자동 로그아웃 임계값 (ms). 기본 10분(600000)
NEXT_PUBLIC_IDLE_TIMEOUT_MS=600000

# 실행 환경 표기 (production 시 console 제거)
NEXT_PUBLIC_APP_ENV=development
